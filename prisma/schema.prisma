generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  role          Role           @default(PARENT)
  fullName      String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  announcements Announcement[]
  parent        Parent?
  teacher       Teacher?

  @@map("users")
}

model Parent {
  id             String    @id @default(cuid())
  userId         String    @unique
  fullName       String
  phone          String
  address        String?
  citizenId      String?
  emergencyPhone String?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students       Student[]

  @@map("parents")
}

model Student {
  id            String         @id @default(cuid())
  parentId      String
  fullName      String
  avatar        String?
  birthDate     DateTime
  gender        Gender
  className     String
  address       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attendances   Attendance[]
  growthRecords GrowthRecord[]
  parent        Parent         @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([className])
  @@map("students")
}

model GrowthRecord {
  id             String   @id @default(cuid())
  studentId      String
  date           DateTime
  height         Float
  weight         Float
  healthNote     String?
  teacherComment String?
  createdAt      DateTime @default(now())
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([date])
  @@map("growth_records")
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@map("attendances")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetClass String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@map("announcements")
}

model Teacher {
  id        String @id @default(cuid())
  userId    String @unique
  fullName  String
  phone     String
  className String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teachers")
}

model TuitionRate {
  id         String   @id @default(cuid())
  className  String   @unique
  dailyRate  Float
  monthlyFee Float    @default(0)
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("tuition_rates")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

enum Role {
  ADMIN
  PARENT
  TEACHER
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}
