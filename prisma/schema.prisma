generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  role          Role           @default(PARENT)
  fullName      String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        Parent?
  announcements Announcement[]

  @@map("users")
}

model Parent {
  id       String    @id @default(cuid())
  userId   String    @unique
  fullName String
  phone    String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]

  @@map("parents")
}

model Student {
  id              String           @id @default(cuid())
  parentId        String
  fullName        String
  avatar          String?
  birthDate       DateTime
  gender          Gender
  className       String
  address         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parent          Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  growthRecords   GrowthRecord[]
  attendances     Attendance[]

  @@map("students")
}

model GrowthRecord {
  id              String   @id @default(cuid())
  studentId       String
  date            DateTime
  height          Float
  weight          Float
  healthNote      String?
  teacherComment  String?
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("growth_records")
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@map("attendances")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetClass String?  // null means all classes
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@map("announcements")
}
