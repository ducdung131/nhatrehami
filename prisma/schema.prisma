generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  TEACHER
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  role          Role           @default(PARENT)
  fullName      String
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        Parent?
  teacher       Teacher?
  announcements Announcement[]

  @@map("users")
}

model Parent {
  id             String    @id @default(cuid())
  userId         String    @unique
  fullName       String
  phone          String
  citizenId      String?   // Căn cước công dân
  address        String?   // Địa chỉ nhà
  emergencyPhone String?   // Số điện thoại người thân khác
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students       Student[]

  @@map("parents")
}

model Student {
  id              String           @id @default(cuid())
  parentId        String
  fullName        String
  avatar          String?
  birthDate       DateTime
  gender          Gender
  className       String
  address         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parent          Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  growthRecords   GrowthRecord[]
  attendances     Attendance[]

  @@index([parentId])
  @@index([className])
  @@map("students")
}

model GrowthRecord {
  id              String   @id @default(cuid())
  studentId       String
  date            DateTime
  height          Float
  weight          Float
  healthNote      String?
  teacherComment  String?
  createdAt       DateTime @default(now())
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([date])
  @@map("growth_records")
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  note      String?
  createdAt DateTime         @default(now())
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([date])
  @@map("attendances")
}

model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String
  targetClass String?  // null means all classes
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@map("announcements")
}

model Teacher {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  phone     String
  className String   // e.g., "Mầm", "Chồi", "Lá"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teachers")
}

model TuitionRate {
  id         String   @id @default(cuid())
  className  String   @unique // e.g., "Lớp Mầm", "Lớp Chồi"
  dailyRate  Float    // Học phí mỗi ngày đi học
  monthlyFee Float    @default(0) // Phí cố định hàng tháng (nếu có)
  note       String?  // Ghi chú
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("tuition_rates")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // public key
  auth      String   // auth secret
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

